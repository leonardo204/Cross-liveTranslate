# Cross-liveTranslate 릴리즈 환경변수 예시
# 이 파일을 .env 로 복사하고 실제 값을 채워 사용하세요.
# .env는 .gitignore에 등록되어 있으므로 저장소에 커밋되지 않습니다.
#
# 사용법:
#   cp .env.example .env
#   # .env 편집 후:
#   scripts/release-cross-livetranslate.sh --version 1.0.0 --upload

# ── 릴리스 대상 저장소 / 앱 이름 ───────────────────────────────────────────
GH_REPO='leonardo204/Cross-liveTranslate'
APP_NAME='Cross-liveTranslate'

# ── minisign 서명 키 ────────────────────────────────────────────────────────
# confUploader / flipMd-Go와 공유하는 Tauri 시절 키. 빈 비밀번호로 보호됨.
# 기본값: ~/.tauri/flipmd.key (변경 불필요하면 주석 처리)
MINISIGN_SECRET_KEY=''
# Tauri 시절 키는 비밀번호가 빈 string("") — 절대 다른 값 넣지 말 것.
MINISIGN_PASSWORD=''

# ── Apple Developer 자격증명 ────────────────────────────────────────────────
# codesign에 사용할 Developer ID Application 인증서 이름
# 예: 'Developer ID Application: 홍길동 (XXXXXXXXXX)'
APPLE_SIGNING_IDENTITY=''
# Apple Developer Program에 등록된 Apple ID
APPLE_ID=''
# appleid.apple.com → 앱 암호 (형식: xxxx-xxxx-xxxx-xxxx)
APPLE_APP_PASSWORD=''
# Developer Portal의 Team ID (10자리 영숫자)
APPLE_TEAM_ID=''
# notarytool keychain profile — release 래퍼가 첫 실행 시 자동 등록
APPLE_NOTARY_PROFILE='CROSS_LIVETRANSLATE_NOTARY'

# ── Tauri CLI signer 경로 ────────────────────────────────────────────────────
# tauri signer가 설치된 npm 프로젝트 루트 (node_modules/@tauri-apps/cli 포함)
TAURI_CLI_DIR=''
